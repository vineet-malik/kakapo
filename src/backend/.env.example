# Example environment for `proxy.py`.
# The server reads the process environment only — export these in your shell
# (or use a tool that injects env vars before starting Python).

# Required for live LLM calls (Gemini OpenAI-compatible API uses the same header name).
OPENAI_API_KEY=

# Optional — defaults shown in proxy.py
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# DEFAULT_MODEL=gemini-flash-latest

# Set to true to run without any API key (slow canned responses for UI testing).
# MOCK_MODE=false
